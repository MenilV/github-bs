{
  "manifest_version": 3,
  "name": "GitHub BS",
  "version": "1.0.0",
  "description": "Bosanski skin za GitHub — ćevapi, rakija i pull requestovi",
  "homepage_url": "https://github.com/menilvukovic/github-bs",
  "permissions": ["storage"],
  "host_permissions": ["*://github.com/*"],
  "content_scripts": [
    {
      "matches": ["*://github.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
