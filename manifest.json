{
  "manifest_version": 3,
  "name": "GitHub BS",
  "version": "1.0.5",
  "description": "Bosanski skin za GitHub — ćevapi, rakija i pull requestovi",
  "homepage_url": "https://github.com/menilvukovic/github-bs",
  "host_permissions": [
    "*://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://github.com/",
        "*://github.com/dashboard"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "crochet.png"
      ],
      "matches": [
        "*://github.com/*"
      ]
    }
  ]
}
